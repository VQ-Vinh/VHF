# === AUTHENTICATION (chọn 1 trong 2) ===

# Cách 1: API Key (lấy từ Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Cách 2: ADC - Application Default Credentials (dùng gcloud auth)
# Chạy: gcloud auth application-default login
# Không cần set GEMINI_API_KEY nếu dùng ADC
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json

# === GOOGLE CLOUD STORAGE (optional) ===
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json
