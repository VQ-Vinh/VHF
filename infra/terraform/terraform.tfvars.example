project_id                   = "prana-elex-production"
environment                  = "production"
deploy_services              = false
region                       = "us-central1"
bucket_name                  = "prana-elex-production-recordings"
api_image                    = "us-central1-docker.pkg.dev/prana-elex-production/prana-elex/prana-api:1.1.0"
admin_image                  = "us-central1-docker.pkg.dev/prana-elex-production/prana-elex/prana-admin:1.1.0"
admin_members                = ["user:admin@example.com"]
admin_emails                 = ["admin@example.com"]
terraform_operator            = "user:admin@example.com"
billing_account              = "000000-000000-000000"
budget_currency_code          = "USD"
monthly_budget_amount        = 100
global_daily_audio_seconds   = 36000
global_monthly_audio_seconds = 500000
input_cost_per_million_tokens  = 0 # Set from the current Vertex AI pricing table.
output_cost_per_million_tokens = 0 # Set from the current Vertex AI pricing table.
api_max_instance_count         = 20
admin_max_instance_count       = 3
manage_project_key_policies    = false
